{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60,
      "excludeFiles": "{backend/**,privade/**,.venv/**,node_modules/**,src/**,public/assets/**,*.pt,*.h5}"
    }
  }
}
